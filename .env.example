# Copy to .env for local development. Never commit .env to git.
# On Databricks Apps, set secrets via app.yaml (see that file for reference).

# ── Your internal Databricks catalog (use this until client provides theirs) ──
ADS_CATALOG=__databricks_internal_catalog_tiles_arclight_1258026991313256

# ── Premier catalog (client will provide — leave blank until then) ────────────
ADS_PREMIER_CATALOG=rhealth_premier_phg
ADS_PREMIER_SCHEMA=bronze_native_premier_phd

# ── Schema names (created automatically by SchemaManager on first run) ─────────
ADS_METADATA_SCHEMA=metadata
ADS_SESSIONS_SCHEMA=sessions
ADS_ATTRITION_SCHEMA=attrition
ADS_SQL_HISTORY_SCHEMA=sql_history
ADS_AUDIT_SCHEMA=audit

# ── Volume paths (use your deepak00 volume) ────────────────────────────────────
ADS_PROTOCOLS_PATH=/Volumes/__databricks_internal_catalog_tiles_arclight_1258026991313256/pd_70492_5267fb1932774c1d_testing/deepak00/protocols
ADS_DATA_DICTIONARY_PATH=/Volumes/__databricks_internal_catalog_tiles_arclight_1258026991313256/pd_70492_5267fb1932774c1d_testing/deepak00/data_dictionary
ADS_EXPORTS_PATH=/Volumes/__databricks_internal_catalog_tiles_arclight_1258026991313256/pd_70492_5267fb1932774c1d_testing/deepak00/exports

# ── Databricks Connection (REQUIRED — all LLM calls go through JnJ workspace) ──
DATABRICKS_HOST=https://dbc-db3d8a4e-f2cf.cloud.databricks.com
DATABRICKS_TOKEN=<paste your new PAT here — never commit this>

# ── LLM API Keys (NOT used — kept blank, all routed via Databricks serving) ────
ADS_ANTHROPIC_API_KEY=
ADS_OPENAI_API_KEY=

# ── AI Search (OPTIONAL — leave blank, app works fine without it) ──────────────
# Set ADS_AI_SEARCH_ENDPOINT only after you create an AI Search endpoint in
# your Databricks workspace. Without it, the app uses Delta keyword metadata search.
ADS_AI_SEARCH_ENDPOINT=
ADS_AI_SEARCH_INDEX=__databricks_internal_catalog_tiles_arclight_1258026991313256.metadata.columns_index
ADS_AI_SEARCH_EMBEDDING_MODEL=

# ── App Settings ───────────────────────────────────────────────────────────────
ADS_APP_NAME=ADS Automation
ADS_APP_VERSION=1.0.0
ADS_LOG_LEVEL=INFO

# ── SQL Execution ──────────────────────────────────────────────────────────────
ADS_MAX_SQL_RETRIES=3
ADS_SQL_EXECUTION_TIMEOUT_SECONDS=300
